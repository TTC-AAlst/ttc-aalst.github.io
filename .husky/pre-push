set -e

cd frontend
bun run format:check
bun run lint
bun run knip
bun run build
bun audit --audit-level=high
bun run test

cd ../backend
echo "Building backend..."
dotnet build Ttc.slnx --verbosity quiet || { echo "Build failed."; exit 1; }
echo "Running backend tests..."
dotnet test Ttc.slnx --verbosity quiet --no-build || { echo "Tests failed."; exit 1; }
