{
  "name": "ttc-front",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "homepage": "https://ttc-aalst.be",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint-fix": "eslint --fix src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "knip": "knip",
    "predeploy": "bun run build",
    "deploy": "gh-pages -d dist --cname ttc-aalst.be"
  },
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@microsoft/signalr": "10.0.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "2.5.1",
    "dayjs": "1.11.20",
    "dompurify": "3.3.3",
    "font-awesome-animation": "1.1.1",
    "normalize.css": "8.0.1",
    "quill": "^2.0.3",
    "react": "^19.2.4",
    "react-avatar-editor": "15.1.0",
    "react-bootstrap": "3.0.0-beta.5",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-ga4": "3.0.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.2",
    "react-select": "5.10.2",
    "redux": "^5.0.1",
    "stacktrace-js": "^2.0.2"
  },
  "overrides": {
    "@restart/hooks": "^0.6.2",
    "react-avatar-editor": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "minimatch": "^10.2.3",
    "immutable": "^5.1.5",
    "flatted": "^3.4.0"
  },
  "knip": {
    "ignoreDependencies": ["husky", "lint-staged"]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.1",
    "eslint": "9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "gh-pages": "^6.3.0",
    "happy-dom": "20.8.8",
    "husky": "^9.1.7",
    "knip": "6.0.5",
    "lint-staged": "16.4.0",
    "prettier": "^3.8.1",
    "sass": "1.98.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vite": "8.0.2",
    "vitest": "4.1.1"
  }
}
