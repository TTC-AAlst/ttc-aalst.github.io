{
  "name": "ttc-front",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "homepage": "https://ttc-aalst.be",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint-fix": "eslint --fix src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "knip": "knip",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist --cname ttc-aalst.be",
    "prepare": "husky"
  },
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@microsoft/signalr": "^8.0.17",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^6.5.0",
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "2.5.1",
    "dayjs": "^1.11.19",
    "font-awesome-animation": "0.0.8",
    "normalize.css": "3.0.3",
    "quill": "^2.0.3",
    "react": "^19.2.4",
    "react-avatar-editor": "13.0.2",
    "react-bootstrap": "3.0.0-beta.5",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-ga4": "^2.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.2",
    "react-select": "5.10.2",
    "redux": "^5.0.1",
    "stacktrace-js": "^2.0.2"
  },
  "overrides": {
    "@restart/hooks": "^0.6.2",
    "react-avatar-editor": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "minimatch": "^10.2.1",
    "ajv": "^8.17.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-avatar-editor": "^13.0.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
